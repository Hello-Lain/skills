#!/usr/bin/env bash
set -euo pipefail

SELF_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SKILL_DIR="$(cd -- "$SELF_DIR/.." && pwd)"

case "${1:-}" in
  on|off|set|status)
    python3 "$SELF_DIR/config.py" "$@"
    ;;
  compress)
    shift
    cd "$SKILL_DIR"
    python3 -m scripts "$@"
    ;;
  *)
    cat <<'EOF'
Usage:
  caveman on [mode]
  caveman off
  caveman set --savings 75
  caveman status
  caveman compress [--level full|--savings 75] FILE
EOF
    ;;
esac
